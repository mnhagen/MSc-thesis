%---------------------------------------------------------------------%
%                     Title page                                      %
%---------------------------------------------------------------------%

\date{}

% Avoid memoir's deprecated title-patching helpers by rendering the
% cover page directly instead of customizing \maketitle via \pretitle
% and related hooks.
\renewcommand{\maketitle}{%
  \begingroup
  \thispagestyle{empty}%
  \begin{flushright}%
    {\Huge \@title\par}%
    \rule{\textwidth}{4pt}\par
    \textit{\Large{\@subtitle}}\par
    \vfill
    \ifcover@picture
      \@coverpicture
    \fi
    \vfill
    {\Large \@author\par}%
  \end{flushright}%
  \endgroup
  \cleardoublepage
}


%-------------------------------------------------------------------%
%                       Formal Title Pages                          %
%-------------------------------------------------------------------%
\def\makeformaltitlepages#1{%
